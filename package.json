{
  "name": "@orion-monitoring/sdk",
  "version": "1.0.0",
  "description": "Official SDK to send logs to Orion Monitoring",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middlewares/express": {
      "import": "./dist/middlewares/express.js",
      "types": "./dist/middlewares/express.d.ts"
    },
    "./middlewares/fastify": {
      "import": "./dist/middlewares/fastify.js",
      "types": "./dist/middlewares/fastify.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "logging",
    "monitoring",
    "orion",
    "sdk"
  ],
  "license": "MIT"
}
