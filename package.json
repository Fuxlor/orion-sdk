{
  "name": "orion-monitoring",
  "version": "0.1.0",
  "description": "Official SDK to send logs to Orion Monitoring",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pidusage": "^2.0.5",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "logging",
    "monitoring",
    "observability",
    "error-tracking",
    "nodejs",
    "orion",
    "sdk"
  ],
  "author": "Orion Monitoring",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USER/orion"
  },
  "homepage": "https://github.com/YOUR_USER/orion/tree/main/orion-sdk#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USER/orion/issues"
  },
  "dependencies": {
    "pidusage": "^4.0.1"
  }
}
